# Copie para .env (local) ou configure na Vercel (Environment Variables).
# NUNCA comite o .env real — ele está no .gitignore.

# Mercado Pago — Access Token (começa com APP_USR-...). Use o MESMO do figurinhas.
MP_ACCESS_TOKEN=

# Google Drive — links das pastas (Compartilhar > Qualquer pessoa com o link > Leitor)
DRIVE_URL_ESSENCIAL=https://drive.google.com/drive/folders/1eXe-aUJbitkEg7iCcyBwPReE1HvKkmiw?usp=share_link
DRIVE_URL_COMBO=https://drive.google.com/drive/folders/1858h9bFBQc4ij9OFBmTUIfvyOrXPpIpV?usp=share_link

# Brevo — entrega por e-mail (mesma chave do figurinhas; remetente "Atividades Bíblicas")
BREVO_API_KEY=
SENDER_EMAIL=

# Meta — API de Conversões (server-side). Pixel ID 993385946435032 está no código.
META_CAPI_TOKEN=
# Opcional: código de teste da aba "Eventos de teste" do Gerenciador (remova depois de validar)
META_CAPI_TEST_CODE=

# URL pública do site (depois do deploy) — usada no event_source_url do CAPI.
# Ex: https://dinamica-biblica.vercel.app
SITE_URL=
